APP_NAME=AI Tradie Receptionist API
APP_VERSION=0.1.0
APP_ENV=local
APP_DEBUG=false
APP_LOG_LEVEL=INFO
ENABLE_API_DOCS=true

BACKEND_PORT=8000

POSTGRES_DB=ai_tradie
POSTGRES_USER=ai_tradie
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ai_tradie:change-me-local-only@postgres:5432/ai_tradie

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

AI_PROVIDER=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CHAT_MODEL=gpt-4.1-mini
AI_EMBEDDING_DIMENSIONS=1536

RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

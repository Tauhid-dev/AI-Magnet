APP_NAME=AI Tradie Receptionist API
APP_VERSION=0.1.0
APP_ENV=local
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=text
REQUEST_ID_HEADER=X-Request-ID
ENABLE_API_DOCS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
BUSINESS_PORTAL_SESSION_SECRET=change-me-before-production
BUSINESS_PORTAL_SESSION_TTL_MINUTES=480
BUSINESS_PORTAL_COOKIE_NAME=ai_magnet_business_session
ADMIN_PORTAL_SESSION_SECRET=change-me-before-production
ADMIN_PORTAL_SESSION_TTL_MINUTES=240
ADMIN_PORTAL_COOKIE_NAME=ai_magnet_admin_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_LOCKOUT_MINUTES=15
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_PER_MINUTE=20
RATE_LIMIT_WIDGET_INIT_PER_MINUTE=120
RATE_LIMIT_CHAT_START_PER_MINUTE=60
RATE_LIMIT_CHAT_MESSAGE_PER_MINUTE=120
RATE_LIMIT_PORTAL_WRITE_PER_MINUTE=60
RATE_LIMIT_ADMIN_WRITE_PER_MINUTE=30
WIDGET_REQUIRE_ALLOWED_ORIGINS=false
PRIVACY_DEFAULT_RETENTION_DAYS=30
LOCAL_DEV_ADMIN_PASSWORD=local-admin-password
LOCAL_DEV_BUSINESS_PASSWORD=local-business-password

BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=8080
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
PUBLIC_BASE_URL=http://127.0.0.1:8080
PUBLIC_HOSTNAME=localhost
LETSENCRYPT_EMAIL=ops@example.com
BACKUP_ENCRYPTION_PASSPHRASE=change-me-before-production

POSTGRES_DB=ai_tradie
POSTGRES_USER=ai_tradie
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ai_tradie:change-me-local-only@postgres:5432/ai_tradie

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
WORKER_QUEUE_NAME=default
WORKER_REDIS_QUEUE_KEY=ai-magnet:jobs:default
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_JOB_LOCK_TIMEOUT_SECONDS=900
WORKER_DEFAULT_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_SECONDS=30
WORKER_RETRY_MAX_SECONDS=300

AI_PROVIDER=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CHAT_MODEL=gpt-4.1-mini
AI_EMBEDDING_DIMENSIONS=1536

RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
WEBSITE_CRAWL_USER_AGENT=AI-MagnetBot/0.1 (+https://example.com/ai-magnet-bot)
WEBSITE_CRAWL_TIMEOUT_SECONDS=10
WEBSITE_CRAWL_MAX_PAGES=10
WEBSITE_CRAWL_MAX_DEPTH=1
WEBSITE_CRAWL_MAX_BYTES=1048576
WEBSITE_CRAWL_MAX_REDIRECTS=5
WEBSITE_CRAWL_RESPECT_ROBOTS=true
DOCUMENT_STORAGE_ROOT=storage/documents
DOCUMENT_UPLOAD_MAX_BYTES=10485760
DOCUMENT_UPLOAD_MAX_PAGES=50
DOCUMENT_OCR_ENABLED=false
DOCUMENT_MALWARE_SCAN_MODE=basic

EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=false
SMTP_STARTTLS=true

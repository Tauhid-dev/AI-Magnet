APP_NAME=AI Tradie Receptionist API
APP_VERSION=0.1.0
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json
REQUEST_ID_HEADER=X-Request-ID
ENABLE_API_DOCS=false
CORS_ALLOWED_ORIGINS=https://example.com

PUBLIC_HOSTNAME=example.com
PUBLIC_BASE_URL=https://example.com
LETSENCRYPT_EMAIL=ops@example.com
NGINX_TEMPLATE=prod.conf.template
NEXT_PUBLIC_API_BASE_URL=/api

BUSINESS_PORTAL_SESSION_SECRET=replace-with-strong-random-secret-at-least-32-chars
BUSINESS_PORTAL_SESSION_TTL_MINUTES=480
BUSINESS_PORTAL_COOKIE_NAME=ai_magnet_business_session
ADMIN_PORTAL_SESSION_SECRET=replace-with-strong-random-secret-at-least-32-chars
ADMIN_PORTAL_SESSION_TTL_MINUTES=240
ADMIN_PORTAL_COOKIE_NAME=ai_magnet_admin_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_FAILED_LOGIN_LIMIT=5
AUTH_LOCKOUT_MINUTES=15

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_PER_MINUTE=20
RATE_LIMIT_WIDGET_INIT_PER_MINUTE=120
RATE_LIMIT_CHAT_START_PER_MINUTE=60
RATE_LIMIT_CHAT_MESSAGE_PER_MINUTE=120
RATE_LIMIT_PORTAL_WRITE_PER_MINUTE=60
RATE_LIMIT_ADMIN_WRITE_PER_MINUTE=30
WIDGET_REQUIRE_ALLOWED_ORIGINS=true
PRIVACY_DEFAULT_RETENTION_DAYS=30

POSTGRES_DB=ai_magnet
POSTGRES_USER=ai_magnet
POSTGRES_PASSWORD=replace-with-strong-random-password
DATABASE_URL=postgresql+psycopg://ai_magnet:replace-with-strong-random-password@postgres:5432/ai_magnet

REDIS_URL=redis://redis:6379/0

AI_PROVIDER=openai-compatible
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=replace-with-provider-api-key
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CHAT_MODEL=gpt-4.1-mini
AI_EMBEDDING_DIMENSIONS=1536

RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=false
SMTP_STARTTLS=true

BACKUP_ENCRYPTION_PASSPHRASE=replace-with-strong-backup-passphrase-at-least-32-chars
